# Exercício 2
def aplicar_desconto(valor, porcentagem):
    desconto = valor * (porcentagem / 100)
    return valor - desconto


# Exercício 3
def e_par(numero):
    return numero % 2 == 0


# Exercício 4
def situacao_aluno(n1, n2, n3):
    media = (n1 + n2 + n3) / 3
    
    if media >= 7:
        status = "Aprovado"
    else:
        status = "Reprovado"
    
    return media, status  # desafio extra atendido


